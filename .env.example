# =============================================================================
# GitHub Personal Access Tokens (REQUIRED)
# =============================================================================
# GitHub Personal Access Tokens for API authentication.
# Supports up to 10 tokens: PAT_1 through PAT_10.
# Tokens are used for GitHub API requests. Get one at:
# https://github.com/settings/tokens
# Required scopes: repo (full control)
PAT_1=

# =============================================================================
# Security - Whitelists (OPTIONAL but recommended)
# =============================================================================
# Comma-separated list of usernames allowed to use the API.
# When empty, all usernames are allowed (not recommended for public use).
# Example: WHITELIST=user1,user2,user3
WHITELIST=

# Comma-separated list of GitHub Gist IDs allowed to be accessed.
# Gist IDs are 20+ character hex strings found in gist URLs.
# Example: GIST_WHITELIST=abc123def456...,789abc123def...
GIST_WHITELIST=

# Comma-separated list of usernames to block from using the API.
# These users will be denied access regardless of WHITELIST.
# Example: BLACKLIST=spam-user,bad-actor
BLACKLIST=

# =============================================================================
# Repository Configuration (OPTIONAL)
# =============================================================================
# Comma-separated list of repository names to exclude from stats.
# Example: EXCLUDE_REPO=repo1,repo2
EXCLUDE_REPO=

# Enable fetching all starred repositories (more accurate but uses more API calls).
# When false, only fetches first 100 starred repos.
FETCH_MULTI_PAGE_STARS=false

# =============================================================================
# Performance & Cache (OPTIONAL)
# =============================================================================
# Cache duration in seconds for API responses.
# Stats card default: 86400 (24 hours), range: 43200-172800
# Top languages default: 345600 (4 days), range: 172800-864000
# Pin card default: 864000 (10 days), range: 86400-864000
# Gist card default: 172800 (2 days), range: 86400-864000
# Example: CACHE_SECONDS=86400
CACHE_SECONDS=

# =============================================================================
# Rate Limiting (OPTIONAL)
# =============================================================================
# Maximum number of requests allowed per time window.
# Default: 100 requests per RATE_LIMIT_WINDOW_MINUTES
RATE_LIMIT_MAX=100

# Time window in minutes for rate limiting.
# Default: 15 minutes
RATE_LIMIT_WINDOW_MINUTES=15

# =============================================================================
# Server Configuration (OPTIONAL)
# =============================================================================
# Server port number. Default: 9000
PORT=9000

# Node environment: development, production, or test.
# Default: development
NODE_ENV=development

# =============================================================================
# Logging (OPTIONAL)
# =============================================================================
# Logging level: debug, info, warn, error.
# Default: info
LOG_LEVEL=info
