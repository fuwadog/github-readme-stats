# GitHub Personal Access Tokens (up to 10: PAT_1 to PAT_10)
PAT_1=

# Whitelist - Comma-separated usernames allowed to use the API
WHITELIST=

# GitHub Gist Whitelist - Comma-separated Gist IDs allowed
GIST_WHITELIST=

# Exclude repositories from stats
EXCLUDE_REPO=

# Enable fetching all starred repos (more accurate but uses more API calls)
FETCH_MULTI_PAGE_STARS=false

# Cache duration in seconds (default: 86400 for stats, 345600 for top-langs)
CACHE_SECONDS=

# Server port (default: 9000)
PORT=9000

# Node environment (development, production, test)
NODE_ENV=development
